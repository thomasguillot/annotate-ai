msgid "Toggle Annotate AI annotation mode"
msgstr "Activer/désactiver le mode annotation Annotate AI"

#: annotate-ai.php:352
msgid "Invalid Telegram bot token format. Expected \"<bot_id>:<secret>\"."
msgstr ""
"Format du jeton du bot Telegram invalide. Format attendu : \"<bot_id>:"
"<secret>\".Format du jeton du bot Telegram invalide. Format attendu : "
"\"<bot_id>:<secret>\"."

