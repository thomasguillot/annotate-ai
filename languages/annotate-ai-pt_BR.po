msgid "Notification method"
msgstr "Método de notificação"

#: build/admin.js:1
msgid "How should the agent be notified when annotations are submitted?"
msgstr "Como o agente deve ser notificado quando as anotações forem enviadas?"

#: build/admin.js:1
msgid "None (agent pulls via REST API)"
msgstr "Nenhum (o agente consulta via REST API)"

#: build/admin.js:1
msgid "Webhook URL"
msgstr "URL de webhook"

#: build/admin.js:1
msgid "Telegram"
msgstr "Telegram"

#: build/admin.js:1
msgid "Your agent should poll this URL on its own schedule:"
msgstr "Seu agente deve consultar este URL no seu próprio ritmo:"

#: build/admin.js:1
msgid "Copied"
msgstr "Copiado"

#: build/admin.js:1
msgid "Copy URL"
msgstr "Copiar URL"

#: build/admin.js:1
msgid "Copy agent snippet"
msgstr "Copiar trecho do agente"

#: build/admin.js:1
msgid "Annotations will be POSTed here as JSON when submitted."
msgstr "As anotações serão enviadas aqui como JSON via POST quando submetidas."

#: build/admin.js:1
msgid "Bearer Token"
msgstr "Token Bearer"

#: build/admin.js:1
msgid "Optional. Sent as Authorization: Bearer <token> header."
msgstr "Opcional. Enviado como cabeçalho Authorization: Bearer <token>."

#: build/admin.js:1
msgid "Bot Token"
msgstr "Token do Bot"

#: build/admin.js:1
msgid "Telegram bot token (from @BotFather)."
msgstr "Token do bot do Telegram (obtido em @BotFather)."

#: build/admin.js:1
msgid "Chat ID"
msgstr "ID do chat"

#: build/admin.js:1
msgid "Telegram chat ID where annotations should be sent."
msgstr "ID do chat do Telegram para o qual as anotações serão enviadas."

