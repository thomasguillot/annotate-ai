msgid "Note"
msgstr "メモ"

#: build/admin.js:2
msgid "Author"
msgstr "作成者"

#: build/admin.js:2
msgid "Actions"
msgstr "操作"

#: build/admin.js:2
msgid "Resolved from admin"
msgstr "管理画面から解決済み"

#: build/admin.js:2
msgid "Failed to resolve annotation."
msgstr "注釈の解決に失敗しました。"

#. translators: %s: annotation note text.
#: build/admin.js:3
msgid "Resolve annotation: %s"
msgstr "注釈を解決: %s"

#: build/admin.js:3
msgid "Resolve"
msgstr "解決"

#: build/admin.js:3
msgid "Failed to clear resolved annotations."
msgstr "解決済みの注釈をクリアできませんでした。"

#: build/admin.js:3
msgid "Clear Resolved"
msgstr "解決済みを削除"

#: build/frontend.js:1
msgid "transparent"
msgstr "透明"

#: build/frontend.js:1
msgid "Selected element:"
msgstr "選択された要素:"

#: build/frontend.js:1
msgid "Text"
msgstr "テキスト"

#: build/frontend.js:1
msgid "Text color"
msgstr "テキストの色"

#: build/frontend.js:1
msgid "Background"
msgstr "背景"

#: build/frontend.js:1
msgid "Affects"
msgstr "対象"

#: build/frontend.js:1
msgid "Pick a breakpoint if this issue is specific to one viewport."
msgstr "特定のビューポート固有の場合はブレークポイントを選択してください。"

#: build/frontend.js:1
msgid "All breakpoints"
msgstr "すべてのブレークポイント"

#: build/frontend.js:1
msgid "Mobile only"
msgstr "モバイルのみ"

#: build/frontend.js:1
msgid "Tablet only"
msgstr "タブレットのみ"

#: build/frontend.js:1
msgid "Desktop only"
msgstr "デスクトップのみ"

#: build/frontend.js:1
msgid "Notes"
msgstr "メモ"

#: build/frontend.js:1
msgid "Anything that doesn’t fit above."
msgstr "上記に当てはまらないこと。"

#: build/frontend.js:1
msgid "e.g. move this above the hero, hide on mobile"
msgstr "例: ヒーローの上に移動、モバイルで非表示"

#: build/frontend.js:1
msgid "Cancel"
msgstr "キャンセル"

#: build/frontend.js:1
msgid "Change at least one value or add a note."
msgstr "少なくとも 1 つの値を変更するか、メモを追加してください。"

#: build/frontend.js:1
msgid "Review change"
msgstr "変更を確認"

#: build/frontend.js:1
msgid "You asked for"
msgstr "要望"

#: build/frontend.js:1
msgid "What the agent did"
msgstr "エージェントの作業"

#: build/frontend.js:1
msgid "The agent did not leave a summary."
msgstr "エージェントは要約を残していません。"

#: build/frontend.js:1
msgid "Not quite"
msgstr "もう少し"

#: build/frontend.js:1
msgid "Looks good"
msgstr "問題なし"

#: build/frontend.js:1
msgid "Annotate AI: toggle annotation mode"
msgstr "Annotate AI: 注釈モードを切り替え"

#: build/frontend.js:1
msgid "Annotation mode on — click any element (Esc to exit)"
msgstr "注釈モード オン — 任意の要素をクリック (Esc で終了)"

#: build/frontend.js:1
msgid "Annotation mode off"
msgstr "注釈モード オフ"

#. translators: %d: annotation number.
#: build/frontend.js:2
msgid "Annotation %d"
msgstr "注釈 %d"

#. translators: %d: number of annotations sent.
#: build/frontend.js:3
msgid "%d annotation sent to agent"
msgid_plural "%d annotations sent to agent"
msgstr[0] ""

