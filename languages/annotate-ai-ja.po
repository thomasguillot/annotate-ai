#. Plugin Name of the plugin
#: annotate-ai.php annotate-ai.php:98 annotate-ai.php:99 build/admin.js:1
msgid "Annotate AI"
msgstr "Annotate AI"

#. Plugin URI of the plugin
#: annotate-ai.php
msgid "https://github.com/thomasguillot/annotate-ai"
msgstr ""

#. Description of the plugin
#: annotate-ai.php
msgid ""
"Point-and-click design feedback for AI agents. Annotate any element on your "
"WordPress site, submit structured feedback, and let your AI agent action it."
msgstr ""

#. Author of the plugin
#: annotate-ai.php
msgid "Thomas Guillot"
msgstr ""

#. Author URI of the plugin
#: annotate-ai.php
msgid "https://thomasguillot.com"
msgstr ""

#: annotate-ai.php:74 build/frontend.js:1
msgid "Annotate"
msgstr "注釈"

#: annotate-ai.php:77
msgid "Toggle Annotate AI annotation mode"
msgstr "Annotate AI 注釈モードを切り替え"

#: annotate-ai.php:352
msgid "Invalid Telegram bot token format. Expected \"<bot_id>:<secret>\"."
msgstr ""
"Telegram ボットトークンの形式が無効です。\"<bot_id>:<secret>\" 形式が必要で"
"す。Telegram ボットトークンの形式が無効です。\"<bot_id>:<secret>\" 形式が必要"
"です。"

#: annotate-ai.php:361
msgid "Telegram chat ID must be numeric."
msgstr "Telegram のチャット ID は数値である必要があります。"

#: annotate-ai.php:370
msgid "Webhook URL must start with http:// or https://."
msgstr "Webhook の URL は http:// または https:// で始まる必要があります。"

#: annotate-ai.php:536 annotate-ai.php:567
msgid "Annotation not found."
msgstr "注釈が見つかりません。"

#: build/admin.js:1
msgid "Failed to copy."
msgstr "コピーに失敗しました。"

#: build/admin.js:1
msgid "Agent Connection"
msgstr "エージェント接続"

#: build/admin.js:1
msgid "Notification method"
msgstr "通知方法"

#: build/admin.js:1
msgid "How should the agent be notified when annotations are submitted?"
msgstr "注釈の送信時にエージェントへどのように通知しますか ?"

#: build/admin.js:1
msgid "None (agent pulls via REST API)"
msgstr "なし (エージェントが REST API から取得)"

#: build/admin.js:1
msgid "Webhook URL"
msgstr "Webhook URL"

#: build/admin.js:1
msgid "Telegram"
msgstr "Telegram"

#: build/admin.js:1
msgid "Your agent should poll this URL on its own schedule:"
msgstr "エージェントは独自のスケジュールでこの URL をポーリングしてください:"

#: build/admin.js:1
msgid "Copied"
msgstr "コピーしました"

#: build/admin.js:1
msgid "Copy URL"
msgstr "URL をコピー"

#: build/admin.js:1
msgid "Copy agent snippet"
msgstr "エージェント用スニペットをコピー"

#: build/admin.js:1
msgid "Annotations will be POSTed here as JSON when submitted."
msgstr "送信時にここへ注釈を JSON として POST します。"

#: build/admin.js:1
msgid "Bearer Token"
msgstr "Bearer トークン"

#: build/admin.js:1
msgid "Optional. Sent as Authorization: Bearer <token> header."
msgstr "任意。Authorization: Bearer <token> ヘッダーとして送信されます。"

#: build/admin.js:1
msgid "Bot Token"
msgstr "ボットトークン"

#: build/admin.js:1
msgid "Telegram bot token (from @BotFather)."
msgstr "Telegram ボットトークン (@BotFather から取得)。"

#: build/admin.js:1
msgid "Chat ID"
msgstr "チャット ID"

#: build/admin.js:1
msgid "Telegram chat ID where annotations should be sent."
msgstr "注釈の送信先となる Telegram のチャット ID。"

#: build/admin.js:1
msgid "Settings saved."
msgstr "設定を保存しました。"

#: build/admin.js:1
msgid "Failed to save."
msgstr "保存に失敗しました。"

#: build/admin.js:1
msgid "Saving…"
msgstr "保存中…"

#: build/admin.js:1
msgid "Save Settings"
msgstr "設定を保存"

#. translators: 1: open annotation count, 2: resolved annotation count.
#: build/admin.js:2
msgid "Annotations (%1$d open, %2$d resolved)"
msgstr "注釈 (オープン %1$d 件、解決済み %2$d 件)"

#: build/admin.js:2
msgid "Loading annotations…"
msgstr "注釈を読み込み中…"

#: build/admin.js:2
msgid ""
"No annotations yet. Browse the frontend and use the annotation toolbar to "
"start."
msgstr ""
"まだ注釈がありません。フロントエンドを開いて注釈ツールバーから作成してくださ"
"い。"

#: build/admin.js:2
msgid "Status"
msgstr "ステータス"

#: build/admin.js:2
msgid "Page"
msgstr "ページ"

#: build/admin.js:2
msgid "Element"
msgstr "要素"

