msgstr "保存に失敗しました — 再試行してください"

#: build/frontend.js:4
msgid "Sending…"
msgstr "送信中…"

#. translators: %d: number of pending annotations.
#: build/frontend.js:5
msgid "Send %d annotation"
msgid_plural "Send %d annotations"
msgstr[0] ""

#: build/frontend.js:5
msgid "Add Annotation"
msgstr "注釈を追加"

#: build/frontend.js:5
msgid "Add"
msgstr "追加"

