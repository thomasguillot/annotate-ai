#: build/frontend.js:7
msgid "Annotation #%d"
msgstr "注釈 #%d"

#: build/frontend.js:7
msgid "Update"
msgstr "更新"

#: build/frontend.js:7
msgid "Annotation updated"
msgstr "注釈を更新しました"

#: build/frontend.js:7
msgid "Failed to update — try again"
msgstr "更新に失敗しました — 再試行してください"

#: build/frontend.js:7
msgid "Marked as verified"
msgstr "確認済みとして記録しました"

#: build/frontend.js:7
msgid "Failed to verify — try again"
msgstr "確認に失敗しました — 再試行してください"

#: build/frontend.js:7
msgid "Reopened for revision"
msgstr "修正のため再オープンしました"

#: build/frontend.js:7
msgid "Failed to reopen — try again"
msgstr "再オープンに失敗しました — 再試行してください"

