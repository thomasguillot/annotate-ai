#: build/frontend.js:6
msgid "Annotation added (%d pending)"
msgid_plural "Annotation added (%d pending)"
msgstr[0] "Annotazione aggiunta (%d in attesa)"
msgstr[1] "Annotazione aggiunta (%d in attesa)"

#: build/frontend.js:6
msgid "Annotation saved"
msgstr "Annotazione salvata"

#. translators: %d: annotation number.
#: build/frontend.js:7
msgid "Annotation #%d"
msgstr "Annotazione n. %d"

#: build/frontend.js:7
msgid "Update"
msgstr "Aggiorna"

#: build/frontend.js:7
msgid "Annotation updated"
msgstr "Annotazione aggiornata"

#: build/frontend.js:7
msgid "Failed to update — try again"
msgstr "Aggiornamento non riuscito — riprova"

#: build/frontend.js:7
msgid "Marked as verified"
msgstr "Contrassegnata come verificata"

#: build/frontend.js:7
msgid "Failed to verify — try again"
msgstr "Verifica non riuscita — riprova"

#: build/frontend.js:7
msgid "Reopened for revision"
msgstr "Riaperta per la revisione"

#: build/frontend.js:7
msgid "Failed to reopen — try again"
msgstr "Riapertura non riuscita — riprova"

