#. Plugin Name of the plugin
#: annotate-ai.php annotate-ai.php:98 annotate-ai.php:99 build/admin.js:1
msgid "Annotate AI"
msgstr "Annotate AI"

#. Plugin URI of the plugin
#: annotate-ai.php
msgid "https://github.com/thomasguillot/annotate-ai"
msgstr ""

#. Description of the plugin
#: annotate-ai.php
msgid ""
"Point-and-click design feedback for AI agents. Annotate any element on your "
"WordPress site, submit structured feedback, and let your AI agent action it."
msgstr ""

#. Author of the plugin
#: annotate-ai.php
msgid "Thomas Guillot"
msgstr ""

#. Author URI of the plugin
#: annotate-ai.php
msgid "https://thomasguillot.com"
msgstr ""

#: annotate-ai.php:74 build/frontend.js:1
msgid "Annotate"
msgstr "Annota"

#: annotate-ai.php:77
msgid "Toggle Annotate AI annotation mode"
msgstr "Attiva/disattiva la modalità annotazione di Annotate AI"

#: annotate-ai.php:352
msgid "Invalid Telegram bot token format. Expected \"<bot_id>:<secret>\"."
msgstr "Formato del token del bot Telegram non valido. Atteso \"<bot_id>:<secret>\"."

#: annotate-ai.php:361
msgid "Telegram chat ID must be numeric."
msgstr "L'ID chat di Telegram deve essere numerico."

#: annotate-ai.php:370
msgid "Webhook URL must start with http:// or https://."
msgstr "L'URL del webhook deve iniziare con http:// o https://."

#: annotate-ai.php:536 annotate-ai.php:567
msgid "Annotation not found."
msgstr "Annotazione non trovata."

#: build/admin.js:1
msgid "Failed to copy."
msgstr "Copia non riuscita."

#: build/admin.js:1
msgid "Agent Connection"
msgstr "Connessione agente"

#: build/admin.js:1
msgid "Notification method"
msgstr "Metodo di notifica"

#: build/admin.js:1
msgid "How should the agent be notified when annotations are submitted?"
msgstr "Come deve essere notificato l’agente quando le annotazioni vengono inviate?"

#: build/admin.js:1
msgid "None (agent pulls via REST API)"
msgstr "Nessuno (l'agente recupera tramite REST API)"

#: build/admin.js:1
msgid "Webhook URL"
msgstr "URL webhook"

#: build/admin.js:1
msgid "Telegram"
msgstr "Telegram"

#: build/admin.js:1
msgid "Your agent should poll this URL on its own schedule:"
msgstr "Il tuo agente deve interrogare questo URL secondo i suoi tempi:"

#: build/admin.js:1
msgid "Copied"
msgstr "Copiato"

#: build/admin.js:1
msgid "Copy URL"
msgstr "Copia URL"

#: build/admin.js:1
msgid "Copy agent snippet"
msgstr "Copia snippet per l’agente"

#: build/admin.js:1
msgid "Annotations will be POSTed here as JSON when submitted."
msgstr "Le annotazioni verranno inviate qui come JSON tramite POST al momento dell’invio."

#: build/admin.js:1
msgid "Bearer Token"
msgstr "Token Bearer"

#: build/admin.js:1
msgid "Optional. Sent as Authorization: Bearer <token> header."
msgstr "Facoltativo. Inviato come header Authorization: Bearer <token>."

#: build/admin.js:1
msgid "Bot Token"
msgstr "Token del bot"

#: build/admin.js:1
msgid "Telegram bot token (from @BotFather)."
msgstr "Token del bot Telegram (da @BotFather)."

#: build/admin.js:1
msgid "Chat ID"
msgstr "ID chat"

#: build/admin.js:1
msgid "Telegram chat ID where annotations should be sent."
msgstr "ID chat di Telegram a cui inviare le annotazioni."

#: build/admin.js:1
msgid "Settings saved."
msgstr "Impostazioni salvate."

#: build/admin.js:1
msgid "Failed to save."
msgstr "Salvataggio non riuscito."

#: build/admin.js:1
msgid "Saving…"
msgstr "Salvataggio…"

#: build/admin.js:1
msgid "Save Settings"
msgstr "Salva impostazioni"

#. translators: 1: open annotation count, 2: resolved annotation count.
#: build/admin.js:2
msgid "Annotations (%1$d open, %2$d resolved)"
msgstr "Annotazioni (%1$d aperte, %2$d risolte)"

#: build/admin.js:2
msgid "Loading annotations…"
msgstr "Caricamento annotazioni…"

#: build/admin.js:2
msgid ""
"No annotations yet. Browse the frontend and use the annotation toolbar to "
"start."
msgstr ""
"Nessuna annotazione ancora. Naviga nel frontend e usa la barra delle "
"annotazioni per iniziare."

