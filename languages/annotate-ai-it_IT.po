msgid "Note"
msgstr "Nota"

#: build/admin.js:2
msgid "Author"
msgstr "Autore"

#: build/admin.js:2
msgid "Actions"
msgstr "Azioni"

#: build/admin.js:2
msgid "Resolved from admin"
msgstr "Risolta dall'amministrazione"

#: build/admin.js:2
msgid "Failed to resolve annotation."
msgstr "Risoluzione dell'annotazione non riuscita."

#. translators: %s: annotation note text.
#: build/admin.js:3
msgid "Resolve annotation: %s"
msgstr "Risolvi annotazione: %s"

#: build/admin.js:3
msgid "Resolve"
msgstr "Risolvi"

#: build/admin.js:3
msgid "Failed to clear resolved annotations."
msgstr "Cancellazione delle annotazioni risolte non riuscita."

#: build/admin.js:3
msgid "Clear Resolved"
msgstr "Cancella risolte"

#: build/frontend.js:1
msgid "transparent"
msgstr "trasparente"

#: build/frontend.js:1
msgid "Selected element:"
msgstr "Elemento selezionato:"

#: build/frontend.js:1
msgid "Text"
msgstr "Testo"

#: build/frontend.js:1
msgid "Text color"
msgstr "Colore del testo"

#: build/frontend.js:1
msgid "Background"
msgstr "Sfondo"

#: build/frontend.js:1
msgid "Affects"
msgstr "Interessa"

#: build/frontend.js:1
msgid "Pick a breakpoint if this issue is specific to one viewport."
msgstr "Seleziona un breakpoint se il problema riguarda un solo viewport."

#: build/frontend.js:1
msgid "All breakpoints"
msgstr "Tutti i breakpoint"

#: build/frontend.js:1
msgid "Mobile only"
msgstr "Solo mobile"

#: build/frontend.js:1
msgid "Tablet only"
msgstr "Solo tablet"

#: build/frontend.js:1
msgid "Desktop only"
msgstr "Solo desktop"

#: build/frontend.js:1
msgid "Notes"
msgstr "Note"

#: build/frontend.js:1
msgid "Anything that doesn’t fit above."
msgstr "Tutto ciò che non rientra nei campi precedenti."

#: build/frontend.js:1
msgid "e.g. move this above the hero, hide on mobile"
msgstr "es. spostalo sopra l’hero, nascondilo su mobile"

#: build/frontend.js:1
msgid "Cancel"
msgstr "Annulla"

#: build/frontend.js:1
msgid "Change at least one value or add a note."
msgstr "Modifica almeno un valore o aggiungi una nota."

#: build/frontend.js:1
msgid "Review change"
msgstr "Rivedi la modifica"

#: build/frontend.js:1
msgid "You asked for"
msgstr "Hai chiesto"

#: build/frontend.js:1
msgid "What the agent did"
msgstr "Cosa ha fatto l’agente"

#: build/frontend.js:1
msgid "The agent did not leave a summary."
msgstr "L’agente non ha lasciato un riepilogo."

#: build/frontend.js:1
msgid "Not quite"
msgstr "Non proprio"

#: build/frontend.js:1
msgid "Looks good"
msgstr "Va bene"

#: build/frontend.js:1
msgid "Annotate AI: toggle annotation mode"
msgstr "Annotate AI: attiva/disattiva la modalità annotazione"

#: build/frontend.js:1
msgid "Annotation mode on — click any element (Esc to exit)"
msgstr ""
"Modalità annotazione attiva — clicca un elemento qualsiasi (Esc per "
"uscire)Modalità annotazione ATTIVA — clicca un elemento qualsiasi (ESC per "
"uscire)"

#: build/frontend.js:1
msgid "Annotation mode off"
msgstr "Modalità annotazione disattivata"

#. translators: %d: annotation number.
#: build/frontend.js:2
msgid "Annotation %d"
msgstr "Annotazione %d"

#. translators: %d: number of annotations sent.
#: build/frontend.js:3
msgid "%d annotation sent to agent"
msgid_plural "%d annotations sent to agent"
msgstr[0] "%d annotazione inviata all’agente"
msgstr[1] "%d annotazioni inviate all’agente"

#. translators: %d: number of annotations saved.
#: build/frontend.js:4
msgid "%d annotation saved"
msgid_plural "%d annotations saved"
msgstr[0] "%d annotazione salvata"
msgstr[1] "%d annotazioni salvate"

#: build/frontend.js:4
msgid "Failed to send — try again"
msgstr "Invio non riuscito — riprova"

#: build/frontend.js:4 build/frontend.js:6
msgid "Failed to save — try again"
msgstr "Salvataggio non riuscito — riprova"

#: build/frontend.js:4
msgid "Sending…"
msgstr "Invio in corso…"

#. translators: %d: number of pending annotations.
#: build/frontend.js:5
msgid "Send %d annotation"
msgid_plural "Send %d annotations"
msgstr[0] "Invia %d annotazione"
msgstr[1] "Invia %d annotazioni"

#: build/frontend.js:5
msgid "Add Annotation"
msgstr "Aggiungi annotazione"

#: build/frontend.js:5
msgid "Add"
msgstr "Aggiungi"

