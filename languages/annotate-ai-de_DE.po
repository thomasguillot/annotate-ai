msgid "Annotate"
msgstr "Anmerken"

#: annotate-ai.php:77
msgid "Toggle Annotate AI annotation mode"
msgstr "Annotate AI Anmerkungsmodus umschalten"

#: annotate-ai.php:352
msgid "Invalid Telegram bot token format. Expected \"<bot_id>:<secret>\"."
msgstr ""
"Ungültiges Telegram-Bot-Token-Format. Erwartet wird \"<bot_id>:"
"<secret>\".Ungültiges Telegram-Bot-Token-Format. Erwartet wird \"<bot_id>:"
"<secret>\"."

