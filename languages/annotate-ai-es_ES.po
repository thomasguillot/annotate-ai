msgid "Annotate"
msgstr "Anotar"

#: annotate-ai.php:77
msgid "Toggle Annotate AI annotation mode"
msgstr "Alternar el modo de anotación Annotate AI"

#: annotate-ai.php:352
msgid "Invalid Telegram bot token format. Expected \"<bot_id>:<secret>\"."
msgstr "Formato no válido del token del bot de Telegram. Se esperaba \"<bot_id>:<secret>\"."

#: annotate-ai.php:361
msgid "Telegram chat ID must be numeric."
msgstr "El ID del chat de Telegram debe ser numérico."

#: annotate-ai.php:370
msgid "Webhook URL must start with http:// or https://."
msgstr "La URL del webhook debe comenzar con http:// o https://."

#: annotate-ai.php:536 annotate-ai.php:567
msgid "Annotation not found."
msgstr "Anotación no encontrada."

